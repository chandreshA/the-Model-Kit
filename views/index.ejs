<%- include('partial/header') -%>

<!-- strong Hero section -->
<section class="editorial-hero">

  <div class="hero-collage">
  <% heroImage.forEach(function(image) { %>
    <img
      src="<%= image.src.large %>"
      alt="<%= image.alt %>"
    >
  <% }) %>
</div>

  <div class="hero-overlay"></div>

  <div class="hero-content">
    <h1 class="hero-title">ModelKit</h1>
    <p class="hero-subtitle">
      Plan shoots. Find your look. Build your modeling brand.
    </p>

    <div class="hero-buttons">
      <a href="#" class="btn-primary">Find Inspiration</a>
      <a href="#" class="btn-secondary">Plan a Shoot</a>
    </div>
  </div>

</section>



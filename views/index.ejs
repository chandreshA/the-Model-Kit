  <div class="row g-4">
  <% featuredImages.forEach(function(item) { %>
    <div class="col-6 col-md-4 col-lg-2">
      <a href="/inspiration?style=<%= item.style %>" class="direction-card">
        <img src="<%= item.image %>" alt="<%= item.alt %>">
        <h3><%= item.name %></h3>
      </a>
    </div>
  <% }) %>
</div>
</section>


<!-- Shoot planning & model book preview -->
<section class="planner-profile-preview">
  <div class="container-fluid px-5">
    <div class="row g-4">

      <div class="col-lg-6">
        <article class="preview-panel shoot-preview">
          <div class="weather-row">
            <div class="weather-icon">☁</div>

            <div>
              <p class="eyebrow">Weather in <%= city %></p>
              <h2><%= weatherData %>, <%= temp %>°F</h2>
            </div>
          </div>

          <div class="panel-rule"></div>

          <p class="eyebrow">Suggested Shoot</p>
          <h5><%= shootSuggestion.title %></h5>
          <p class="shoot-style">
            <span>Style:</span> <%= shootSuggestion.style %>
          </p>
          <p class="shoot-style">
            <span>Location:</span> <%= shootSuggestion.location %>
          </p>
          <p class="shoot-style">
            <span>Palette:</span> <%= shootSuggestion.palette %>
          </p>


          <a href="/planner" class="dark-button">
            Plan My Shoot
            <span>→</span>
          </a>
        </article>
      </div>

      <div class="col-lg-6">
        <article class="preview-panel profile-preview">
          <img
            src="/images/profile-preview.jpg"
            alt="Model profile preview"
            class="profile-preview-img"
          >

          <div class="profile-preview-content">
            <p class="eyebrow gold">Model Book</p>
            <h2>Chandresh A.</h2>
            <p class="profile-location">New York, NY</p>

            <div class="panel-rule"></div>

            <p class="profile-stats">6' / 182 cm</p>

            <div class="profile-tags">
              <span>Fashion</span>
              <span>Editorial</span>
              <span>Commercial</span>
              <span>Runway</span>
            </div>
          </div>
        </article>
      </div>

    </div>
  </div>
</section>

<!-- market explorer teaser (use static content so the homepage isn't slowed down)-->

<%- include('partial/footer') -%>
